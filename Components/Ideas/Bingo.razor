@using hi_site_ideas_blazor.Models
@using hi_site_ideas_blazor.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@rendermode InteractiveServer

<div class="bingo-page">
    @if (TabParam == "rules" && ActiveEvent != null)
    {
        <h2 class="page-heading">Rules</h2>
        @if (!string.IsNullOrEmpty(ActiveEvent.Rules))
        {
            <div class="rules-content">
                @foreach (var line in ActiveEvent.Rules.Split('\n'))
                {
                    @if (string.IsNullOrWhiteSpace(line)) { <br /> }
                    else { <p>@line</p> }
                }
            </div>
        }
        else
        {
            <p class="empty-state">No rules set for this event.</p>
        }
    }
    else if (TabParam == "prizes" && ActiveEvent != null)
    {
        <h2 class="page-heading">Prizes</h2>
        @if (!string.IsNullOrEmpty(ActiveEvent.Prizes))
        {
            <div class="rules-content">
                @foreach (var line in ActiveEvent.Prizes.Split('\n'))
                {
                    @if (string.IsNullOrWhiteSpace(line)) { <br /> }
                    else { <p>@line</p> }
                }
            </div>
        }
        else
        {
            <p class="empty-state">No prizes set for this event.</p>
        }
    }
    else if (TabParam == "past")
    {
        <h2 class="page-heading">Past Events</h2>
        @if (PastEvents.Count > 0)
        {
            <div class="event-list">
                @foreach (var ev in PastEvents)
                {
                    <BingoEventCard @key="ev.Id" Event="@ev" DefaultOpen="@(PastEvents.Count == 1)"
                        IsAdmin="@_isAdmin" UserTeamId="@_userTeam?.Id" MemberNames="@_memberNames"
                        OnUpdate="UpdateEvent" OnDelete="DeleteEvent" />
                }
            </div>
        }
        else
        {
            <p class="empty-state">No past bingo events yet.</p>
        }
    }
    else
    {
        @if (_isAdmin)
        {
            <button class="new-event-btn" @onclick="() => _showNewModal = true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="M12 5v14"/>
                </svg>
                New Bingo
            </button>
        }

        @if (_showNewModal)
        {
            <div class="modal-overlay" @onclick="() => _showNewModal = false">
                <div class="modal-content modal-wide" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h2>New Bingo</h2>
                        <button class="modal-close" @onclick="() => _showNewModal = false">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                            </svg>
                        </button>
                    </div>
                    <BingoEventEditor Event="@_blankEvent" IsNew="true" MemberNames="@_memberNames" OnSave="HandleNewSave" OnCancel="() => _showNewModal = false" />
                </div>
            </div>
        }

        @if (ActiveEvent != null)
        {
            <BingoEventCard Event="@ActiveEvent" DefaultOpen="true"
                IsAdmin="@_isAdmin" UserTeamId="@_userTeam?.Id" MemberNames="@_memberNames"
                OnUpdate="UpdateEvent" OnDelete="DeleteEvent" />
        }
        else
        {
            <p class="empty-state">No active bingo events.</p>
        }
    }
</div>

@code {
    private const string CurrentUser = "Lex 26";

    [SupplyParameterFromQuery(Name = "view")] private string? ViewParam { get; set; }
    [SupplyParameterFromQuery(Name = "tab")] private string? TabParam { get; set; }

    private bool _isAdmin => string.Equals(ViewParam, "admin", StringComparison.OrdinalIgnoreCase);

    private bool _showNewModal;
    private List<BingoEvent> _events = [];
    private List<string> _memberNames = [];
    private BingoTeam? _userTeam;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _events = await db.BingoEvents
            .Include(e => e.Tiles).ThenInclude(t => t.RequirementGroups).ThenInclude(g => g.Options).ThenInclude(o => o.Requirements)
            .Include(e => e.Tiles).ThenInclude(t => t.TeamTiles).ThenInclude(tt => tt.Submissions).ThenInclude(s => s.Entries)
            .Include(e => e.Teams).ThenInclude(t => t.TeamTiles).ThenInclude(tt => tt.Submissions).ThenInclude(s => s.Entries)
            .Include(e => e.Teams).ThenInclude(t => t.Members)
            .OrderByDescending(e => e.CreatedAt)
            .ToListAsync();

        _memberNames = await db.Members.OrderBy(m => m.DisplayName).Select(m => m.DisplayName).ToListAsync();

        _userTeam = _events
            .SelectMany(e => e.Teams)
            .FirstOrDefault(t => t.Members.Any(m => m.Name.Equals(CurrentUser, StringComparison.OrdinalIgnoreCase)));
    }

    private List<BingoEvent> VisibleEvents => _isAdmin ? _events : _events.Where(e => e.Published).ToList();

    private BingoEvent? ActiveEvent => VisibleEvents.FirstOrDefault(e => e.Status != BingoEventStatus.Completed);

    private List<BingoEvent> PastEvents => VisibleEvents
        .Where(e => e.Status == BingoEventStatus.Completed).ToList();

    private BingoEvent _blankEvent => new()
    {
        Title = "",
        BoardSize = 5,
        Status = BingoEventStatus.Upcoming,
    };

    private async Task HandleNewSave(BingoEvent draft)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.BingoEvents.Add(draft);
        await db.SaveChangesAsync();
        _events.Insert(0, draft);
        _showNewModal = false;
    }

    private async Task UpdateEvent(BingoEvent updated)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.BingoEvents
            .Include(e => e.Tiles).ThenInclude(t => t.RequirementGroups).ThenInclude(g => g.Options).ThenInclude(o => o.Requirements)
            .Include(e => e.Tiles).ThenInclude(t => t.TeamTiles)
            .Include(e => e.Teams).ThenInclude(t => t.TeamTiles)
            .FirstOrDefaultAsync(e => e.Id == updated.Id);
        if (existing == null) return;

        existing.Title = updated.Title;
        existing.Description = updated.Description;
        existing.Rules = updated.Rules;
        existing.Prizes = updated.Prizes;
        existing.BoardSize = updated.BoardSize;
        existing.Status = updated.Status;
        existing.Published = updated.Published;
        existing.StartsAt = updated.StartsAt;
        existing.EndsAt = updated.EndsAt;

        // Remove old tiles and their requirements
        foreach (var tile in existing.Tiles)
        {
            foreach (var group in tile.RequirementGroups)
            {
                foreach (var option in group.Options)
                    db.BingoRequirements.RemoveRange(option.Requirements);
                db.BingoRequirementOptions.RemoveRange(group.Options);
            }
            db.BingoRequirementGroups.RemoveRange(tile.RequirementGroups);
        }
        db.BingoTeamTiles.RemoveRange(existing.Tiles.SelectMany(t => t.TeamTiles));
        db.BingoTiles.RemoveRange(existing.Tiles);

        existing.Tiles = updated.Tiles.Select(t => new BingoTile
        {
            Position = t.Position, Title = t.Title, Description = t.Description,
            ImageUrl = t.ImageUrl, Points = t.Points,
            RequirementGroups = t.RequirementGroups.Select(g => new BingoRequirementGroup
            {
                Label = g.Label, Mode = g.Mode,
                Options = g.Options.Select(o => new BingoRequirementOption
                {
                    Label = o.Label,
                    Requirements = o.Requirements.Select(r => new BingoRequirement { Label = r.Label, TargetCount = r.TargetCount }).ToList(),
                }).ToList(),
            }).ToList(),
        }).ToList();

        db.BingoTeamTiles.RemoveRange(existing.Teams.SelectMany(t => t.TeamTiles));
        db.BingoTeams.RemoveRange(existing.Teams);
        existing.Teams = updated.Teams.Select(t => new BingoTeam
        {
            Name = t.Name, Color = t.Color,
            Members = t.Members.Select(m => new BingoTeamMember { Name = m.Name }).ToList(),
        }).ToList();

        await db.SaveChangesAsync();

        var idx = _events.FindIndex(e => e.Id == updated.Id);
        if (idx >= 0) _events[idx] = existing;
    }

    private async Task DeleteEvent(BingoEvent ev)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.BingoEvents
            .Include(e => e.Tiles).ThenInclude(t => t.TeamTiles)
            .Include(e => e.Teams).ThenInclude(t => t.TeamTiles)
            .FirstOrDefaultAsync(e => e.Id == ev.Id);
        if (existing == null) return;

        db.BingoTeamTiles.RemoveRange(existing.Tiles.SelectMany(t => t.TeamTiles));
        db.BingoTeamTiles.RemoveRange(existing.Teams.SelectMany(t => t.TeamTiles));
        db.BingoTiles.RemoveRange(existing.Tiles);
        db.BingoTeams.RemoveRange(existing.Teams);
        db.BingoEvents.Remove(existing);
        await db.SaveChangesAsync();

        _events.RemoveAll(e => e.Id == ev.Id);
    }
}
