@using hi_site_ideas_blazor.Models
@using hi_site_ideas_blazor.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@rendermode InteractiveServer

<div class="giveaways-demo">
    <button class="new-giveaway-btn" @onclick="() => _showModal = true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="M12 5v14"/>
        </svg>
        New Giveaway
    </button>

    @if (_showModal)
    {
        <div class="modal-overlay" @onclick="() => _showModal = false">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h2>New Giveaway</h2>
                    <button class="modal-close" @onclick="() => _showModal = false">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                        </svg>
                    </button>
                </div>
                <EditPanel Giveaway="@_blankGiveaway" IsNew="true" MemberNames="@_memberNames" OnSave="HandleNewSave" OnCancel="() => _showModal = false" />
            </div>
        </div>
    }

    <div class="giveaway-tabs">
        <button class="giveaway-tab @(_tab == "active" ? "active" : "")" @onclick='() => _tab = "active"'>
            In Progress (@Active.Count)
        </button>
        <button class="giveaway-tab @(_tab == "completed" ? "active" : "")" @onclick='() => _tab = "completed"'>
            Completed (@Completed.Count)
        </button>
    </div>

    <div class="giveaway-list">
        @foreach (var g in (_tab == "active" ? Active : Completed))
        {
            <GiveawayCard @key="g.Id" Giveaway="@g" DefaultOpen="@(_tab == "active")" MemberNames="@_memberNames" OnUpdate="UpdateGiveaway" />
        }
        @if (_tab == "active" && Active.Count == 0)
        {
            <p class="empty-state">No active giveaways right now.</p>
        }
        @if (_tab == "completed" && Completed.Count == 0)
        {
            <p class="empty-state">No completed giveaways yet.</p>
        }
    </div>
</div>

@code {
    private string _tab = "active";
    private bool _showModal;
    private List<Giveaway> _giveaways = [];
    private List<string> _memberNames = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _memberNames = await db.Members.OrderBy(m => m.DisplayName).Select(m => m.DisplayName).ToListAsync();
        _giveaways = await db.Giveaways.Include(g => g.Prizes).Include(g => g.Guesses).OrderByDescending(g => g.Id).ToListAsync();
    }

    private Giveaway _blankGiveaway => new()
    {
        Title = "",
        Boss = "",
        Player = "",
        Item = "",
        Status = GiveawayStatus.Active,
        StartKc = 0,
        CurrentKc = 0,
        Prizes = [new Prize { Label = "Closest guess", Type = "closest", Reward = "" }],
        Guesses = [],
    };

    private List<Giveaway> Active => _giveaways.Where(g => g.Status == GiveawayStatus.Active).ToList();
    private List<Giveaway> Completed => _giveaways.Where(g => g.Status != GiveawayStatus.Active).ToList();

    private async Task UpdateGiveaway(Giveaway updated)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var existing = await db.Giveaways.Include(g => g.Prizes).Include(g => g.Guesses).FirstOrDefaultAsync(g => g.Id == updated.Id);
        if (existing == null) return;

        existing.Title = updated.Title;
        existing.Boss = updated.Boss;
        existing.Player = updated.Player;
        existing.Item = updated.Item;
        existing.Status = updated.Status;
        existing.StartKc = updated.StartKc;
        existing.CurrentKc = updated.CurrentKc;
        existing.DropKc = updated.DropKc;

        db.Prizes.RemoveRange(existing.Prizes);
        existing.Prizes = updated.Prizes.Select(p => new Prize { Label = p.Label, Type = p.Type, Reward = p.Reward, Count = p.Count }).ToList();

        db.Guesses.RemoveRange(existing.Guesses);
        existing.Guesses = updated.Guesses.Select(g => new Guess { Name = g.Name, GuessKc = g.GuessKc }).ToList();

        await db.SaveChangesAsync();

        var idx = _giveaways.FindIndex(g => g.Id == updated.Id);
        if (idx >= 0) _giveaways[idx] = existing;
    }

    private async Task HandleNewSave(Giveaway draft)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Giveaways.Add(draft);
        await db.SaveChangesAsync();

        _giveaways.Insert(0, draft);
        _showModal = false;
    }
}
