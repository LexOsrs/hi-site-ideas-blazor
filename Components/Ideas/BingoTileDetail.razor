@using hi_site_ideas_blazor.Models
@using hi_site_ideas_blazor.Data
@using hi_site_ideas_blazor.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject DiscordService Discord

<div class="modal-overlay" @onclick="() => OnClose.InvokeAsync()">
    <div class="modal-content modal-wide" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h2>@Tile.Title</h2>
            <button class="modal-close" @onclick="() => OnClose.InvokeAsync()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                </svg>
            </button>
        </div>

        <div class="detail-tabs">
            <button class="detail-tab @(_tab == "details" ? "active" : "")" @onclick='() => _tab = "details"'>Details</button>
            <button class="detail-tab @(_tab == "submissions" ? "active" : "")" @onclick='() => _tab = "submissions"'>
                Screenshots
                @if (SubmissionCount > 0)
                {
                    <span class="tab-count">@SubmissionCount</span>
                }
            </button>
        </div>

        @if (_tab == "details")
        {
            <div class="tile-detail">
                @if (!string.IsNullOrEmpty(Tile.ImageUrl))
                {
                    <img class="tile-detail-image" src="@Tile.ImageUrl" alt="@Tile.Title" />
                }

                @if (!string.IsNullOrEmpty(Tile.Description))
                {
                    <div class="tile-description">
                        @foreach (var line in Tile.Description.Split('\n'))
                        {
                            @if (string.IsNullOrWhiteSpace(line)) { <br /> }
                            else { <p>@line</p> }
                        }
                    </div>
                }

                <div class="tile-info-row">
                    <span class="tile-info-label">Points</span>
                    <span class="tile-info-value">@Tile.Points</span>
                </div>

                @foreach (var team in TeamsToShow)
                {
                    var tt = Tile.TeamTiles.FirstOrDefault(x => x.BingoTeamId == team.Id);
                    var approved = tt?.GetApprovedSubmissions() ?? Enumerable.Empty<BingoSubmission>();
                    var computedStatus = ComputeStatus(approved);

                    <div class="tile-team-section">
                        <div class="team-status-row">
                            <span class="team-dot" style="background: @team.Color"></span>
                            <span class="team-status-name">@team.Name</span>
                            <span class="tile-status-badge tile-status-@computedStatus.css">
                                @computedStatus.label
                            </span>
                        </div>

                        @if (Tile.HasRequirements)
                        {
                            @foreach (var group in Tile.RequirementGroups)
                            {
                                var showGroupLabel = Tile.RequirementGroups.Count > 1 || group.Mode == RequirementMode.OneOf;
                                var groupSatisfied = group.IsSatisfied(approved);

                                <div class="req-group @(groupSatisfied ? "complete" : "")">
                                    @if (showGroupLabel)
                                    {
                                        <div class="req-group-header">
                                            <span class="req-group-label">@group.Label @(group.Mode == RequirementMode.OneOf ? "(pick one)" : "")</span>
                                            @if (groupSatisfied)
                                            {
                                                <span class="req-group-done">Complete</span>
                                            }
                                        </div>
                                    }

                                    @if (group.Mode == RequirementMode.All)
                                    {
                                        @foreach (var req in group.Options.SelectMany(o => o.Requirements))
                                        {
                                            var progress = BingoRequirementOption.GetProgress(approved, req.Label);
                                            var done = progress >= req.TargetCount;
                                            <div class="req-row @(done ? "done" : "")">
                                                <span class="req-check">@(done ? "\u2713" : "")</span>
                                                <span class="req-label">@req.Label</span>
                                                <span class="req-progress">@progress.ToString("N0") / @req.TargetCount.ToString("N0")</span>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        @foreach (var option in group.Options.OrderByDescending(o => o.CompletionFraction(approved)))
                                        {
                                            var optComplete = option.IsComplete(approved);
                                            var hasProgress = option.Requirements.Any(r => approved.Any(s => s.RequirementLabel == r.Label && s.Amount > 0));
                                            <div class="req-option @(optComplete ? "option-complete" : "") @(hasProgress && !optComplete ? "option-active" : "")">
                                                <span class="req-option-label">@option.Label</span>
                                                @foreach (var req in option.Requirements)
                                                {
                                                    var progress = BingoRequirementOption.GetProgress(approved, req.Label);
                                                    var done = progress >= req.TargetCount;
                                                    <div class="req-row @(done ? "done" : "")">
                                                        <span class="req-check">@(done ? "\u2713" : "")</span>
                                                        <span class="req-label">@req.Label</span>
                                                        <span class="req-progress">@progress.ToString("N0") / @req.TargetCount.ToString("N0")</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }

                            @if (approved.Any(s => s.Entries.Any(e => e.Amount > 0)))
                            {
                                <div class="contribution-list">
                                    <h4>Contributions</h4>
                                    @foreach (var sub in approved.Where(s => s.Entries.Any(e => e.Amount > 0)).OrderBy(s => s.SubmittedAt))
                                    {
                                        @foreach (var entry in sub.Entries.Where(e => e.Amount > 0))
                                        {
                                            <div class="contribution-row">
                                                <span class="contribution-name">@sub.SubmittedBy</span>
                                                <span class="contribution-detail">@entry.RequirementLabel</span>
                                                <span class="contribution-value">+@entry.Amount.ToString("N0")</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="submissions-tab">

                @{ var pending = GetSubmissions(SubmissionStatus.Pending); }
                @if (pending.Any())
                {
                    <div class="submission-group">
                        <h4 class="submission-group-header pending-header">Pending Review (@pending.Count())</h4>
                        @foreach (var sub in pending)
                        {
                            <div class="submission-card pending">
                                <div class="submission-card-header">
                                    @if (sub.Type == SubmissionType.Start)
                                    {
                                        <span class="submission-type-badge type-start">START</span>
                                    }
                                    else
                                    {
                                        @foreach (var entry in sub.Entries)
                                        {
                                            <span class="submission-type-badge type-progress">+@entry.Amount @entry.RequirementLabel</span>
                                        }
                                    }
                                    <span class="submission-by">@sub.SubmittedBy</span>
                                    <span class="submission-date">@sub.SubmittedAt.ToString("MMM d")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(sub.ImageUrl))
                                {
                                    <img src="@sub.ImageUrl" alt="@(sub.Caption ?? "Screenshot")" class="submission-img" @onclick="() => _lightboxUrl = sub.ImageUrl" @onclick:stopPropagation="true" />
                                }
                                @if (!string.IsNullOrEmpty(sub.Caption))
                                {
                                    <p class="submission-caption">@sub.Caption</p>
                                }
                                @if (IsAdmin)
                                {
                                    <div class="review-actions">
                                        @if (sub.Type == SubmissionType.Progress)
                                        {
                                            @foreach (var entry in sub.Entries)
                                            {
                                                var e = entry;
                                                <div class="review-entry-row">
                                                    <select class="review-label-select" value="@e.RequirementLabel" @onchange="v => e.RequirementLabel = v.Value?.ToString() ?? e.RequirementLabel">
                                                        @foreach (var label in AllRequirementLabels)
                                                        {
                                                            <option value="@label" selected="@(label == e.RequirementLabel)">@label</option>
                                                        }
                                                    </select>
                                                    <input type="number" class="review-amount-input" value="@e.Amount" @onchange="v => e.Amount = int.TryParse(v.Value?.ToString(), out var val) ? val : e.Amount" min="1" />
                                                    <button class="edit-icon-btn" @onclick="() => sub.Entries.Remove(e)">
                                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                                    </button>
                                                </div>
                                            }
                                            <button class="add-prize-btn" @onclick="() => AddEntryToSubmission(sub)">+ Add item</button>
                                        }
                                        <div class="review-buttons">
                                            @{
                                                var canApprove = sub.Type == SubmissionType.Start || sub.Entries.Any(e => !string.IsNullOrWhiteSpace(e.RequirementLabel) && e.Amount > 0);
                                            }
                                            <button class="approve-btn" @onclick="() => ReviewSubmission(sub, SubmissionStatus.Approved)" disabled="@(!canApprove)"
                                                    title="@(!canApprove ? "Add at least one item before approving" : "")">Approve</button>
                                            <button class="deny-btn" @onclick="() => ReviewSubmission(sub, SubmissionStatus.Denied)">Deny</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span class="pending-label">Awaiting moderator review</span>
                                }
                            </div>
                        }
                    </div>
                }

                @{ var approved = GetSubmissions(SubmissionStatus.Approved); }
                @if (approved.Any())
                {
                    <div class="submission-group">
                        <h4 class="submission-group-header">Approved (@approved.Count())</h4>
                        @foreach (var sub in approved)
                        {
                            <div class="submission-card approved">
                                <div class="submission-card-header">
                                    @if (sub.Type == SubmissionType.Start)
                                    {
                                        <span class="submission-type-badge type-start">START</span>
                                    }
                                    else
                                    {
                                        @foreach (var entry in sub.Entries)
                                        {
                                            <span class="submission-type-badge type-progress">+@entry.Amount @entry.RequirementLabel</span>
                                        }
                                    }
                                    <span class="submission-by">@sub.SubmittedBy</span>
                                    <span class="submission-date">@sub.SubmittedAt.ToString("MMM d")</span>
                                    <span class="approved-badge">Approved</span>
                                </div>
                                @if (!string.IsNullOrEmpty(sub.ImageUrl))
                                {
                                    <img src="@sub.ImageUrl" alt="@(sub.Caption ?? "Screenshot")" class="submission-img" @onclick="() => _lightboxUrl = sub.ImageUrl" @onclick:stopPropagation="true" />
                                }
                                @if (!string.IsNullOrEmpty(sub.Caption))
                                {
                                    <p class="submission-caption">@sub.Caption</p>
                                }
                                @if (IsAdmin)
                                {
                                    @if (_editingSubmissionId == sub.Id)
                                    {
                                        <div class="review-actions">
                                            <div class="review-entry-row">
                                                <label style="font-size: 0.78rem; color: var(--text-dim); min-width: 70px">Credited to</label>
                                                <input value="@sub.SubmittedBy" @onchange="v => sub.SubmittedBy = v.Value?.ToString() ?? sub.SubmittedBy" style="flex: 1" />
                                            </div>
                                            @if (sub.Type == SubmissionType.Progress)
                                            {
                                                @foreach (var entry in sub.Entries)
                                                {
                                                    var e = entry;
                                                    <div class="review-entry-row">
                                                        <select class="review-label-select" value="@e.RequirementLabel" @onchange="v => e.RequirementLabel = v.Value?.ToString() ?? e.RequirementLabel">
                                                            @foreach (var label in AllRequirementLabels)
                                                            {
                                                                <option value="@label" selected="@(label == e.RequirementLabel)">@label</option>
                                                            }
                                                        </select>
                                                        <input type="number" class="review-amount-input" value="@e.Amount" @onchange="v => e.Amount = int.TryParse(v.Value?.ToString(), out var val) ? val : e.Amount" min="1" />
                                                        <button class="edit-icon-btn" @onclick="() => sub.Entries.Remove(e)">
                                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                                        </button>
                                                    </div>
                                                }
                                                <button class="add-prize-btn" @onclick="() => AddEntryToSubmission(sub)">+ Add item</button>
                                            }
                                            <div class="review-buttons">
                                                <button class="save-btn" style="padding: 5px 14px; font-size: 0.82rem" @onclick="() => SaveEntryEdits(sub)">Save</button>
                                                <button class="cancel-btn" style="padding: 5px 14px; font-size: 0.82rem" @onclick="() => _editingSubmissionId = null">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="submission-admin-actions">
                                            @if (sub.Type == SubmissionType.Progress)
                                            {
                                                <button class="submission-action-link" @onclick="() => _editingSubmissionId = sub.Id">Edit items</button>
                                            }
                                            <button class="submission-action-link danger" @onclick="() => DeleteSubmission(sub)">Delete</button>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }

                @{ var denied = GetSubmissions(SubmissionStatus.Denied); }
                @if (denied.Any())
                {
                    <div class="submission-group">
                        <h4 class="submission-group-header denied-header">Denied (@denied.Count())</h4>
                        @foreach (var sub in denied)
                        {
                            <div class="submission-card denied">
                                <div class="submission-card-header">
                                    <span class="submission-type-badge type-denied">DENIED</span>
                                    <span class="submission-by">@sub.SubmittedBy</span>
                                    <span class="submission-date">@sub.SubmittedAt.ToString("MMM d")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(sub.Caption))
                                {
                                    <p class="submission-caption">@sub.Caption</p>
                                }
                                @if (IsAdmin)
                                {
                                    <div class="submission-admin-actions">
                                        <button class="submission-action-link" @onclick="() => ReviewSubmission(sub, SubmissionStatus.Pending)">Re-open</button>
                                        <button class="submission-action-link danger" @onclick="() => DeleteSubmission(sub)">Delete</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                @if (!pending.Any() && !approved.Any() && !denied.Any())
                {
                    <p class="empty-screenshots">No submissions yet.</p>
                }
            </div>
        }
    </div>
</div>

@if (_lightboxUrl != null)
{
    <div class="lightbox-overlay" @onclick="() => _lightboxUrl = null">
        <img src="@_lightboxUrl" class="lightbox-img" />
    </div>
}

@code {
    [Parameter] public BingoTile Tile { get; set; } = new();
    [Parameter] public BingoEvent Event { get; set; } = new();
    [Parameter] public int? SelectedTeamId { get; set; }
    [Parameter] public bool IsAdmin { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string _tab = "details";
    private string? _lightboxUrl;
    private int? _editingSubmissionId;

    private IEnumerable<BingoTeam> TeamsToShow => IsAdmin
        ? Event.Teams
        : Event.Teams.Where(t => SelectedTeamId.HasValue && t.Id == SelectedTeamId.Value);

    private List<string> AllRequirementLabels => Tile.RequirementGroups
        .SelectMany(g => g.Options)
        .SelectMany(o => o.Requirements)
        .Select(r => r.Label)
        .Distinct()
        .ToList();



    private int SubmissionCount
    {
        get
        {
            if (IsAdmin) return Tile.TeamTiles.Sum(tt => tt.Submissions.Count);
            if (SelectedTeamId.HasValue) return Tile.TeamTiles.Where(x => x.BingoTeamId == SelectedTeamId.Value).Sum(tt => tt.Submissions.Count);
            return 0;
        }
    }

    private IEnumerable<BingoSubmission> GetSubmissions(SubmissionStatus status)
    {
        IEnumerable<BingoTeamTile> teamTiles;
        if (IsAdmin)
            teamTiles = SelectedTeamId.HasValue
                ? Tile.TeamTiles.Where(tt => tt.BingoTeamId == SelectedTeamId.Value)
                : Tile.TeamTiles;
        else
            teamTiles = Tile.TeamTiles.Where(tt => SelectedTeamId.HasValue && tt.BingoTeamId == SelectedTeamId.Value);

        return teamTiles.SelectMany(tt => tt.Submissions).Where(s => s.Status == status).OrderByDescending(s => s.SubmittedAt);
    }

    private (string label, string css) ComputeStatus(IEnumerable<BingoSubmission> approved)
    {
        if (Tile.HasRequirements && Tile.IsComplete(approved))
            return ("Complete", "completed");
        if (approved.Any(s => s.Entries.Any(e => e.Amount > 0)))
            return ("Partially Complete", "inprogress");
        return ("Not Started", "notstarted");
    }

    private async Task DeleteSubmission(BingoSubmission sub)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.BingoSubmissions.Include(s => s.Entries).FirstOrDefaultAsync(s => s.Id == sub.Id);
        if (entity == null) return;

        db.BingoSubmissionEntries.RemoveRange(entity.Entries);
        db.BingoSubmissions.Remove(entity);
        await db.SaveChangesAsync();

        // Remove from in-memory
        var teamTile = Tile.TeamTiles.FirstOrDefault(tt => tt.Submissions.Contains(sub));
        teamTile?.Submissions.Remove(sub);
    }

    private async Task SaveEntryEdits(BingoSubmission sub)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.BingoSubmissions.Include(s => s.Entries).FirstOrDefaultAsync(s => s.Id == sub.Id);
        if (entity == null) return;

        entity.SubmittedBy = sub.SubmittedBy;
        db.BingoSubmissionEntries.RemoveRange(entity.Entries);
        entity.Entries = sub.Entries
            .Where(e => !string.IsNullOrWhiteSpace(e.RequirementLabel) && e.Amount > 0)
            .Select(e => new BingoSubmissionEntry { RequirementLabel = e.RequirementLabel, Amount = e.Amount })
            .ToList();
        await db.SaveChangesAsync();

        // Update in-memory
        sub.Entries = entity.Entries;
        _editingSubmissionId = null;
    }

    private void AddEntryToSubmission(BingoSubmission sub)
    {
        var labels = AllRequirementLabels;
        sub.Entries.Add(new BingoSubmissionEntry { RequirementLabel = labels.FirstOrDefault() ?? "", Amount = 1 });
    }

    private async Task ReviewSubmission(BingoSubmission sub, SubmissionStatus newStatus)
    {
        // Block approving progress submissions without items
        if (newStatus == SubmissionStatus.Approved && sub.Type == SubmissionType.Progress
            && !sub.Entries.Any(e => !string.IsNullOrWhiteSpace(e.RequirementLabel) && e.Amount > 0))
            return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.BingoSubmissions.Include(s => s.Entries).FirstOrDefaultAsync(s => s.Id == sub.Id);
        if (entity == null) return;

        entity.Status = newStatus;
        entity.ReviewedBy = "Admin";
        entity.ReviewedAt = DateTime.UtcNow;

        // Sync entry changes from the in-memory edits
        db.BingoSubmissionEntries.RemoveRange(entity.Entries);
        entity.Entries = sub.Entries.Select(e => new BingoSubmissionEntry
        {
            RequirementLabel = e.RequirementLabel, Amount = e.Amount,
        }).ToList();

        await db.SaveChangesAsync();

        sub.Status = newStatus;
        sub.ReviewedBy = "Admin";
        sub.ReviewedAt = DateTime.UtcNow;

        if (newStatus == SubmissionStatus.Approved)
        {
            // Add ✅ to the original Discord message
            if (entity.DiscordMessageId.HasValue)
            {
                var teamTileForReaction = await db.BingoTeamTiles.FirstOrDefaultAsync(tt => tt.Id == entity.BingoTeamTileId);
                if (teamTileForReaction?.DiscordThreadId != null)
                    await Discord.AddReaction(teamTileForReaction.DiscordThreadId.Value, entity.DiscordMessageId.Value, "✅");
            }
            await CheckCompletionNotifications(db, entity);
        }
        else if (newStatus == SubmissionStatus.Denied && entity.DiscordMessageId.HasValue)
        {
            var teamTileForReaction = await db.BingoTeamTiles.FirstOrDefaultAsync(tt => tt.Id == entity.BingoTeamTileId);
            if (teamTileForReaction?.DiscordThreadId != null)
                await Discord.AddReaction(teamTileForReaction.DiscordThreadId.Value, entity.DiscordMessageId.Value, "❌");
        }
    }

    private async Task CheckCompletionNotifications(AppDbContext db, BingoSubmission sub)
    {
        var teamTile = await db.BingoTeamTiles
            .Include(tt => tt.Tile).ThenInclude(t => t.RequirementGroups).ThenInclude(g => g.Options).ThenInclude(o => o.Requirements)
            .Include(tt => tt.Submissions).ThenInclude(s => s.Entries)
            .Include(tt => tt.Team)
            .FirstOrDefaultAsync(tt => tt.Id == sub.BingoTeamTileId);
        if (teamTile == null) return;

        var tile = teamTile.Tile;
        var team = teamTile.Team;
        var approved = teamTile.GetApprovedSubmissions();

        if (!tile.HasRequirements || !tile.IsComplete(approved)) return;
        var approvedWithout = approved.Where(s => s.Id != sub.Id);
        if (tile.IsComplete(approvedWithout)) return;

        await Discord.NotifyTileComplete(teamTile, tile);
        await Discord.NotifyTeamChannel(team, $"🎉 **{tile.Title}** tile completed! (+{tile.Points} pts)");

        // Check lines
        var ev = await db.BingoEvents
            .Include(e => e.Tiles).ThenInclude(t => t.RequirementGroups).ThenInclude(g => g.Options).ThenInclude(o => o.Requirements)
            .Include(e => e.Tiles).ThenInclude(t => t.TeamTiles).ThenInclude(tt => tt.Submissions).ThenInclude(s => s.Entries)
            .FirstOrDefaultAsync(e => e.Id == tile.BingoEventId);
        if (ev == null || ev.LineBonusPoints <= 0) return;

        var size = ev.BoardSize;
        var completedPositions = new HashSet<int>();
        foreach (var tt in ev.Tiles.SelectMany(t => t.TeamTiles).Where(tt => tt.BingoTeamId == team.Id))
        {
            var t = ev.Tiles.First(x => x.Id == tt.BingoTileId);
            if (t.HasRequirements && t.IsComplete(tt.GetApprovedSubmissions()))
                completedPositions.Add(t.Position);
        }

        var prevPositions = new HashSet<int>(completedPositions);
        prevPositions.Remove(tile.Position);

        var newLines = new List<string>();
        for (int r = 0; r < size; r++)
            if (Enumerable.Range(0, size).All(c => completedPositions.Contains(r * size + c))
                && !Enumerable.Range(0, size).All(c => prevPositions.Contains(r * size + c)))
                newLines.Add($"Row {r + 1}");
        for (int c = 0; c < size; c++)
            if (Enumerable.Range(0, size).All(r => completedPositions.Contains(r * size + c))
                && !Enumerable.Range(0, size).All(r => prevPositions.Contains(r * size + c)))
                newLines.Add($"Column {c + 1}");
        if (Enumerable.Range(0, size).All(i => completedPositions.Contains(i * size + i))
            && !Enumerable.Range(0, size).All(i => prevPositions.Contains(i * size + i)))
            newLines.Add("Diagonal (↘)");
        if (Enumerable.Range(0, size).All(i => completedPositions.Contains(i * size + (size - 1 - i)))
            && !Enumerable.Range(0, size).All(i => prevPositions.Contains(i * size + (size - 1 - i))))
            newLines.Add("Diagonal (↙)");

        foreach (var line in newLines)
            await Discord.NotifyTeamChannel(team, $"🏆 **{line} complete!** (+{ev.LineBonusPoints} bonus pts)");

        var totalTiles = ev.Tiles.Count(t => t.HasRequirements);
        if (totalTiles > 0 && completedPositions.Count == totalTiles && prevPositions.Count < totalTiles)
            await Discord.NotifyTeamChannel(team, $"👑 **FULL BOARD COMPLETE!** Every tile complete! Now go touch some grass 👑");
    }
}
